# Database Configuration
DB_USER=bookuser
DB_PASSWORD=bookpassword
DB_NAME=book_review_db
DB_PORT=5432
DB_HOST=postgres

# Database Connection String
DATABASE_URL=postgresql://bookuser:bookpassword@postgres:5432/book_review_db?schema=public

# pgAdmin Configuration
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# Backend Configuration
NODE_ENV=development
API_PORT=3000
API_HOST=http://localhost:3000

# Frontend Configuration
VITE_API_URL=http://localhost:3000
VITE_API_TIMEOUT=30000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=24h

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Prisma Configuration
PRISMA_DATABASE_URL=postgresql://bookuser:bookpassword@postgres:5432/book_review_db?schema=public

# Application Configuration
LOG_LEVEL=debug
ENABLE_CORS=true
CORS_ORIGIN=http://localhost:5173

# Development Tools
DEBUG=book-review:*
